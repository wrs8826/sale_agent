{
  "app_id":     "你的飞书 App ID（cli_xxxxxxxxxxxxxxxx）",
  "app_secret": "你的飞书 App Secret",
  "verification_token": "",
  "encrypt_key": "",
  "mcpServers": {
    "lark-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a", "你的飞书 App ID",
        "-s", "你的飞书 App Secret"
      ]
    }
  }
}
