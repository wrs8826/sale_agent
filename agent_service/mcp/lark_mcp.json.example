{
  "app_id": "YOUR_LARK_APP_ID",
  "app_secret": "YOUR_LARK_APP_SECRET",
  "verification_token": "",
  "encrypt_key": "",
  "oauth_redirect_uri": "http://YOUR_SERVER_IP:5001/lark/oauth/callback",
  "mcpServers": {
    "lark-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "YOUR_LARK_APP_ID",
        "-s",
        "YOUR_LARK_APP_SECRET"
      ]
    },
    "builtin-tools": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "-m",
        "agent_service.mcp.builtin_mcp_server"
      ]
    }
  }
}
